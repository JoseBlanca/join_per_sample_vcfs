.claude/settings.local.json

# GIAB human benchmark: track the runner/analysis scripts and README, but keep
# the heavy local data out of git (reference genome, BAM/CRAM, truth VCFs,
# generated .psp/.vcf results — gigabytes, fetched/built locally).
benchmarks/giab/*
!benchmarks/giab/src/
!benchmarks/giab/README.md

# tomato2 hidden-paralog-filter study: track the scripts + the region definition,
# keep the heavy/derivable data out (CRAMs, .psp, windowed coverage, VCF/parquet
# results — gigabytes, all built locally from the scripts).
benchmarks/tomato2/*
!benchmarks/tomato2/src/
!benchmarks/tomato2/regions_n160_200kb.bed
!benchmarks/tomato2/README.md
